<%- include("../partials/header") %>
<%- include("../partials/navbar") %>

<div class="page-wrapper">
  <%- include("../partials/messages") %>

  <!-- ── Header ── -->
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
      <h1 class="page-title mb-1">Employees</h1>
      <p class="page-subtitle mb-0">
        <i class="bi bi-people me-1 text-primary"></i>Manage and search all employee records
      </p>
    </div>
    <a href="/employees/new" class="btn btn-primary px-4 py-2 rounded-pill fw-semibold">
      <i class="bi bi-person-plus-fill me-2"></i>Add Employee
    </a>
  </div>

  <!-- ── Search ── -->
  <form method="GET" action="/employees" class="card mb-4" style="border-radius:var(--radius-md);">
    <div class="card-body py-3">
      <div class="row g-2 align-items-end">
        <div class="col-md-10">
          <div class="input-group search-group">
            <span class="input-group-text">
              <i class="bi bi-search text-muted"></i>
            </span>
            <input
              type="text"
              class="form-control"
              name="search"
              value="<%= search %>"
              placeholder="Search by name, ID, email or department&hellip;"
            />
          </div>
        </div>
        <div class="col-md-2 d-grid">
          <button class="btn btn-primary fw-semibold">Search</button>
        </div>
      </div>
    </div>
  </form>

  <!-- ── Table ── -->
  <div class="card" style="border-radius:var(--radius-md);">
    <div class="table-responsive modern-table-wrap">
      <table class="table table-hover align-middle mb-0 modern-table">
        <thead>
          <tr>
            <th><i class="bi bi-hash me-1"></i>ID</th>
            <th><i class="bi bi-person me-1"></i>Name</th>
            <th><i class="bi bi-diagram-3 me-1"></i>Department</th>
            <th><i class="bi bi-briefcase me-1"></i>Designation</th>
            <th><i class="bi bi-currency-rupee me-1"></i>Salary</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (employees.length === 0) { %>
            <tr>
              <td colspan="7" class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-2 d-block mb-2 opacity-25"></i>
                No employees found.
              </td>
            </tr>
          <% } %>
          <% employees.forEach((employee) => { %>
            <tr>
              <td>
                <span class="badge bg-light text-dark border fw-semibold" style="font-size:.78rem;">
                  <%= employee.employeeId %>
                </span>
              </td>
              <td class="fw-semibold"><%= employee.fullName %></td>
              <td><%= employee.department %></td>
              <td class="text-muted"><%= employee.designation %></td>
              <td class="fw-semibold">&#8377;<%= employee.currentSalary.toLocaleString() %></td>
              <td>
                <span class="status-badge
                  <%= employee.status === 'Active'   ? 'status-active'   :
                      employee.status === 'On Leave' ? 'status-leave'    :
                                                       'status-inactive' %>">
                  <% if (employee.status === 'Active')   { %><i class="bi bi-circle-fill me-1" style="font-size:.5rem;"></i><% } %>
                  <%= employee.status %>
                </span>
              </td>
              <td class="text-nowrap">
                <a href="/employees/<%= employee._id %>" class="btn btn-sm btn-outline-primary me-1 rounded-pill px-2">
                  <i class="bi bi-eye me-1"></i>View
                </a>
                <a href="/employees/<%= employee._id %>/edit" class="btn btn-sm btn-outline-secondary me-1 rounded-pill px-2">
                  <i class="bi bi-pencil me-1"></i>Edit
                </a>
                <form action="/employees/<%= employee._id %>/delete" method="POST" class="d-inline"
                  onsubmit="return confirm('Delete <%= employee.fullName %>? This cannot be undone.')">
                  <button class="btn btn-sm btn-outline-danger rounded-pill px-2">
                    <i class="bi bi-trash me-1"></i>Delete
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% if (employees.length > 0) { %>
      <div class="card-footer bg-white text-muted" style="font-size:.8rem;">
        Showing <%= employees.length %> employee<%= employees.length !== 1 ? 's' : '' %>
        <% if (search) { %> for &ldquo;<strong><%= search %></strong>&rdquo;<% } %>
      </div>
    <% } %>
  </div>
</div>

<%- include("../partials/footer") %>
