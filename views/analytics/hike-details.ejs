<%- include("../partials/header") %>
<%- include("../partials/navbar") %>
<div class="page-wrapper">
  <div class="d-flex align-items-center gap-3 mb-4">
    <a href="/dashboard" class="btn btn-sm btn-outline-secondary rounded-pill"><i class="bi bi-arrow-left"></i> Dashboard</a>
    <h1 class="page-title mb-0">Active Hikes</h1>
  </div>
  <div class="insight-card mb-4"><strong><%= employeesWithHikes.length %></strong> employees with hikes &bull; <strong><%= totalHikes %></strong> hike records</div>
  <div class="card mb-4"><div class="card-header fw-bold">Employees with Hikes</div>
    <div class="table-responsive modern-table-wrap">
      <table class="table modern-table mb-0">
        <thead><tr><th>Name</th><th>Department</th><th>Current Salary</th><th></th></tr></thead>
        <tbody>
          <% employeesWithHikes.forEach((e) => { %>
            <tr>
              <td><%= e.fullName %></td><td><%= e.department %></td>
              <td>&#8377;<%= e.currentSalary.toLocaleString() %></td>
              <td><a href="/employee/<%= e._id %>" class="btn btn-sm btn-outline-primary rounded-pill">Profile</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="card"><div class="card-header fw-bold">Hike History</div>
    <div class="table-responsive modern-table-wrap">
      <table class="table table-hover modern-table mb-0">
        <thead><tr><th>Employee</th><th>Previous</th><th>New</th><th>Hike %</th><th>Reason</th><th>Date</th></tr></thead>
        <tbody>
          <% hikeRecords.forEach((h) => { %>
            <tr>
              <td><%= h.employee?.fullName || '—' %></td>
              <td>&#8377;<%= h.previousSalary.toLocaleString() %></td>
              <td>&#8377;<%= h.newSalary.toLocaleString() %></td>
              <td><span class="hike-badge">+<%= h.hikePercentage %>%</span></td>
              <td><%= h.reason %></td>
              <td><%= new Date(h.createdAt).toLocaleDateString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include("../partials/footer") %>
