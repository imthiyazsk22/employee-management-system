<%- include("../partials/header") %>
<%- include("../partials/navbar") %>

<div class="page-wrapper">
  <%- include("../partials/messages") %>

  <!-- ── Page header ── -->
  <div class="d-flex align-items-center gap-3 mb-4">
    <a href="/employees" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
      <i class="bi bi-arrow-left me-1"></i>Back
    </a>
    <div class="flex-grow-1">
      <h1 class="page-title mb-0"><%= employee.fullName %></h1>
      <span class="page-subtitle"><%= employee.employeeId %> &bull; <%= employee.department %></span>
    </div>
    <a href="/employees/<%= employee._id %>/edit" class="btn btn-outline-primary rounded-pill px-3">
      <i class="bi bi-pencil me-1"></i>Edit
    </a>
  </div>

  <div class="row g-4 mb-4">
    <!-- ── Profile card ── -->
    <div class="col-lg-7">
      <div class="card h-100" style="border-radius:var(--radius-md);">
        <div class="card-header d-flex align-items-center justify-content-between">
          <span class="fw-bold d-flex align-items-center gap-2">
            <i class="bi bi-person-badge-fill text-primary"></i>Employee Profile
          </span>
          <span class="status-badge
            <%= employee.status === 'Active'   ? 'status-active'   :
                employee.status === 'On Leave' ? 'status-leave'    :
                                                 'status-inactive' %>">
            <%= employee.status %>
          </span>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <div class="profile-meta-card">
                <div class="profile-meta-label">Employee ID</div>
                <div class="profile-meta-value">
                  <i class="bi bi-upc-scan text-primary"></i><%= employee.employeeId %>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="profile-meta-card">
                <div class="profile-meta-label">Full Name</div>
                <div class="profile-meta-value">
                  <i class="bi bi-person-fill text-primary"></i><%= employee.fullName %>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="profile-meta-card">
                <div class="profile-meta-label">Email</div>
                <div class="profile-meta-value">
                  <i class="bi bi-envelope-fill text-primary"></i><%= employee.email %>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="profile-meta-card">
                <div class="profile-meta-label">Department</div>
                <div class="profile-meta-value">
                  <i class="bi bi-diagram-3-fill text-primary"></i><%= employee.department %>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="profile-meta-card">
                <div class="profile-meta-label">Designation</div>
                <div class="profile-meta-value">
                  <i class="bi bi-briefcase-fill text-primary"></i><%= employee.designation %>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="profile-meta-card">
                <div class="profile-meta-label">Joining Date</div>
                <div class="profile-meta-value">
                  <i class="bi bi-calendar-event-fill text-primary"></i>
                  <%= new Date(employee.joiningDate).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %>
                </div>
              </div>
            </div>
            <div class="col-12">
              <div class="profile-meta-card" style="background:var(--primary-light);border-color:#BFDBFE;">
                <div class="profile-meta-label" style="color:var(--primary);">Current Salary</div>
                <div class="profile-meta-value" style="font-size:1.35rem;color:var(--primary);">
                  <i class="bi bi-currency-rupee text-primary"></i>
                  &#8377;<%= employee.currentSalary.toLocaleString() %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Salary & Hike forms ── -->
    <div class="col-lg-5 d-flex flex-column gap-3">
      <div class="card" style="border-radius:var(--radius-md);">
        <div class="card-header d-flex align-items-center gap-2">
          <i class="bi bi-currency-rupee text-primary"></i>
          <span class="fw-semibold">Update Salary</span>
        </div>
        <div class="card-body">
          <form method="POST" action="/employees/<%= employee._id %>/salary">
            <div class="mb-3">
              <label class="form-label">New Salary (₹)</label>
              <input type="number" class="form-control" name="newSalary" min="0" step="0.01"
                placeholder="Enter new salary amount" required />
            </div>
            <div class="mb-3">
              <label class="form-label">Reason</label>
              <input type="text" class="form-control" name="reason" placeholder="e.g. Promotion, Market adjustment" />
            </div>
            <button class="btn btn-primary w-100 fw-semibold">
              <i class="bi bi-arrow-up-circle me-2"></i>Update Salary
            </button>
          </form>
        </div>
      </div>

      <div class="card" style="border-radius:var(--radius-md);">
        <div class="card-header d-flex align-items-center gap-2">
          <i class="bi bi-award-fill text-success"></i>
          <span class="fw-semibold">Apply Hike</span>
        </div>
        <div class="card-body">
          <form method="POST" action="/employees/<%= employee._id %>/hike">
            <div class="mb-3">
              <label class="form-label">Hike Percentage (%)</label>
              <div class="input-group">
                <input type="number" class="form-control" name="hikePercentage"
                  min="0.01" step="0.01" placeholder="e.g. 10" required />
                <span class="input-group-text">%</span>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label">Reason</label>
              <input type="text" class="form-control" name="reason" placeholder="e.g. Annual appraisal" />
            </div>
            <button class="btn btn-success w-100 fw-semibold">
              <i class="bi bi-graph-up-arrow me-2"></i>Apply Hike
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Salary history ── -->
  <div class="card" style="border-radius:var(--radius-md);">
    <div class="card-header d-flex align-items-center gap-2">
      <i class="bi bi-clock-history text-primary"></i>
      <span class="fw-bold">Salary History</span>
    </div>
    <div class="table-responsive modern-table-wrap">
      <table class="table table-hover align-middle mb-0 modern-table">
        <thead>
          <tr>
            <th>Date &amp; Time</th>
            <th>Previous Salary</th>
            <th>New Salary</th>
            <th>Hike %</th>
            <th>Reason</th>
            <th>Changed By</th>
          </tr>
        </thead>
        <tbody>
          <% if (salaryHistory.length === 0) { %>
            <tr>
              <td colspan="6" class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-2 d-block mb-2 opacity-25"></i>
                No salary history found.
              </td>
            </tr>
          <% } %>
          <% salaryHistory.forEach((item) => { %>
            <tr>
              <td style="font-size:.82rem;"><%= new Date(item.createdAt).toLocaleString('en-IN') %></td>
              <td class="text-muted">&#8377;<%= item.previousSalary.toLocaleString() %></td>
              <td class="fw-semibold">&#8377;<%= item.newSalary.toLocaleString() %></td>
              <td><span class="hike-badge">+<%= item.hikePercentage %>%</span></td>
              <td><%= item.reason %></td>
              <td>
                <span class="badge bg-light text-dark border">
                  <i class="bi bi-person me-1"></i><%= item.changedBy %>
                </span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include("../partials/footer") %>
