<%- include("../partials/header") %>
<%- include("../partials/navbar") %>
<div class="page-wrapper">
  <div class="d-flex align-items-center gap-3 mb-4">
    <a href="/dashboard" class="btn btn-sm btn-outline-secondary rounded-pill"><i class="bi bi-arrow-left"></i> Dashboard</a>
    <h1 class="page-title mb-0">Salary Expenses</h1>
  </div>
  <div class="row g-3 mb-4">
    <div class="col-md-4"><div class="insight-card"><div class="text-muted small">Total Payroll</div><div class="fs-3 fw-bold">&#8377;<%= totalExpense.toLocaleString() %></div></div></div>
    <div class="col-md-4"><div class="insight-card"><div class="text-muted small">Paid</div><div class="fs-3 fw-bold text-success">&#8377;<%= paidTotal.toLocaleString() %></div></div></div>
    <div class="col-md-4"><div class="insight-card"><div class="text-muted small">Pending</div><div class="fs-3 fw-bold text-danger">&#8377;<%= pendingTotal.toLocaleString() %></div></div></div>
  </div>
  <div class="card mb-4"><div class="card-header fw-bold">Department Breakdown</div>
    <div class="table-responsive modern-table-wrap">
      <table class="table modern-table mb-0">
        <thead><tr><th>Department</th><th>Employees</th><th>Total Salary</th><th>Paid</th></tr></thead>
        <tbody>
          <% byDepartment.forEach((d) => { %>
            <tr><td><%= d._id %></td><td><%= d.count %></td><td>&#8377;<%= d.totalSalary.toLocaleString() %></td><td><%= d.paidCount %></td></tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="card"><div class="card-header fw-bold">All Employees</div>
    <div class="table-responsive modern-table-wrap">
      <table class="table table-hover modern-table mb-0">
        <thead><tr><th>Name</th><th>Dept</th><th>Salary</th><th>Payment</th></tr></thead>
        <tbody>
          <% employees.forEach((e) => { %>
            <tr>
              <td><a href="/employee/<%= e._id %>"><%= e.fullName %></a></td>
              <td><%= e.department %></td>
              <td>&#8377;<%= e.currentSalary.toLocaleString() %></td>
              <td><span class="status-badge <%= (e.paymentStatus||'Pending')==='Paid'?'payment-status-paid':'payment-status-pending' %>"><%= e.paymentStatus||'Pending' %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include("../partials/footer") %>
