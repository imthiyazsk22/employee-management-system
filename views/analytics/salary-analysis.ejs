<%- include("../partials/header") %>
<%- include("../partials/navbar") %>
<div class="page-wrapper">
  <div class="d-flex align-items-center gap-3 mb-4">
    <a href="/dashboard" class="btn btn-sm btn-outline-secondary rounded-pill"><i class="bi bi-arrow-left"></i> Dashboard</a>
    <h1 class="page-title mb-0">Salary Analysis</h1>
  </div>
  <div class="row g-3 mb-4">
    <div class="col-md-3"><div class="insight-card"><div class="text-muted small">Employees</div><div class="fs-3 fw-bold"><%= count %></div></div></div>
    <div class="col-md-3"><div class="insight-card"><div class="text-muted small">Average</div><div class="fs-4 fw-bold" style="color:var(--orange);">&#8377;<%= Math.round(average).toLocaleString() %></div></div></div>
    <div class="col-md-3"><div class="insight-card"><div class="text-muted small">Highest</div>
      <% if (highest) { %><div class="fw-bold"><%= highest.fullName %></div><div>&#8377;<%= highest.currentSalary.toLocaleString() %></div><% } %>
    </div></div>
    <div class="col-md-3"><div class="insight-card"><div class="text-muted small">Lowest</div>
      <% if (lowest) { %><div class="fw-bold"><%= lowest.fullName %></div><div>&#8377;<%= lowest.currentSalary.toLocaleString() %></div><% } %>
    </div></div>
  </div>
  <div class="row g-4">
    <div class="col-lg-6">
      <div class="card"><div class="card-header fw-bold">Avg Salary by Department</div>
        <div class="table-responsive modern-table-wrap">
          <table class="table modern-table mb-0">
            <thead><tr><th>Department</th><th>Count</th><th>Avg</th><th>Max</th></tr></thead>
            <tbody>
              <% deptStats.forEach((d) => { %>
                <tr><td><%= d._id %></td><td><%= d.count %></td><td>&#8377;<%= Math.round(d.avgSalary).toLocaleString() %></td><td>&#8377;<%= d.maxSalary.toLocaleString() %></td></tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="card"><div class="card-header fw-bold">Salary Ranges</div>
        <ul class="list-group list-group-flush">
          <% salaryRanges.forEach((r) => { %>
            <li class="list-group-item d-flex justify-content-between"><span><%= r.label %></span><strong><%= r.count %></strong></li>
          <% }) %>
        </ul>
      </div>
    </div>
  </div>
</div>
<%- include("../partials/footer") %>
