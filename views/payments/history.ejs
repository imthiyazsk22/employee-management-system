<%- include("../partials/header") %>
<%- include("../partials/navbar") %>
<div class="page-wrapper">
  <%- include("../partials/messages") %>
  <div class="d-flex align-items-center gap-3 mb-4">
    <a href="/dashboard" class="btn btn-sm btn-outline-secondary rounded-pill"><i class="bi bi-arrow-left"></i> Dashboard</a>
    <h1 class="page-title mb-0">Payment History</h1>
  </div>

  <form method="GET" action="/payment-history" class="filter-card">
    <div class="row g-2 align-items-end">
      <div class="col-md-4">
        <label class="form-label">Employee Name</label>
        <input type="text" name="employee" class="form-control" value="<%= filters.employee %>" placeholder="Search name" />
      </div>
      <div class="col-md-3">
        <label class="form-label">Department</label>
        <select name="department" class="form-select">
          <option value="">All</option>
          <% departments.forEach((d) => { %>
            <option value="<%= d %>" <%= filters.department === d ? 'selected' : '' %>><%= d %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label">Status</label>
        <select name="status" class="form-select">
          <option value="">All</option>
          <option value="Paid" <%= filters.status === 'Paid' ? 'selected' : '' %>>Paid</option>
          <option value="Pending" <%= filters.status === 'Pending' ? 'selected' : '' %>>Pending</option>
        </select>
      </div>
      <div class="col-md-2 d-grid"><button class="btn btn-pay-salary">Filter</button></div>
    </div>
  </form>

  <div class="card border-0" style="border-radius:var(--radius-md);">
    <div class="table-responsive modern-table-wrap">
      <table class="table table-hover modern-table mb-0">
        <thead>
          <tr>
            <th>Employee</th>
            <th>Department</th>
            <th>Transaction ID</th>
            <th>Amount</th>
            <th>Date &amp; Time</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% if (payments.length === 0) { %>
            <tr><td colspan="6" class="text-center py-5 text-muted">No payment records found.</td></tr>
          <% } %>
          <% payments.forEach((p) => { %>
            <tr>
              <td class="fw-semibold"><%= p.employeeName %></td>
              <td><%= p.department %></td>
              <td><code class="small"><%= p.transactionId %></code></td>
              <td>&#8377;<%= p.amount.toLocaleString() %></td>
              <td><%= new Date(p.paidAt).toLocaleString('en-IN') %></td>
              <td>
                <span class="status-badge <%= p.status === 'Paid' ? 'payment-status-paid' : 'payment-status-pending' %>">
                  <%= p.status %>
                </span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include("../partials/footer") %>
