<%- include("../partials/header") %>
<%- include("../partials/navbar") %>

<div class="page-wrapper">
  <%- include("../partials/messages") %>

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
      <h1 class="page-title mb-1">Employees</h1>
      <p class="page-subtitle mb-0">Search and filter workforce records</p>
    </div>
    <a href="/employees/new" class="btn btn-pay-salary px-4"><i class="bi bi-person-plus-fill me-2"></i>Add Employee</a>
  </div>

  <form method="GET" action="/employees" class="filter-card">
    <div class="row g-2 align-items-end">
      <div class="col-md-3">
        <label class="form-label">Search by name</label>
        <input type="text" name="search" class="form-control" value="<%= filters.search %>" placeholder="Name, ID, email" />
      </div>
      <div class="col-md-2">
        <label class="form-label">Department</label>
        <select name="department" class="form-select">
          <option value="">All</option>
          <% departments.forEach((d) => { %>
            <option value="<%= d %>" <%= filters.department === d ? 'selected' : '' %>><%= d %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Payment</label>
        <select name="paymentStatus" class="form-select">
          <option value="">All</option>
          <option value="Pending" <%= filters.paymentStatus === 'Pending' ? 'selected' : '' %>>Pending</option>
          <option value="Paid" <%= filters.paymentStatus === 'Paid' ? 'selected' : '' %>>Paid</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Min salary</label>
        <input type="number" name="salaryMin" class="form-control" value="<%= filters.salaryMin %>" min="0" />
      </div>
      <div class="col-md-2">
        <label class="form-label">Max salary</label>
        <input type="number" name="salaryMax" class="form-control" value="<%= filters.salaryMax %>" min="0" />
      </div>
      <div class="col-md-1 d-grid"><button class="btn btn-primary">Go</button></div>
    </div>
  </form>

  <div class="card border-0" style="border-radius:var(--radius-md);">
    <div class="table-responsive modern-table-wrap">
      <table class="table table-hover align-middle mb-0 modern-table">
        <thead>
          <tr>
            <th>ID</th><th>Name</th><th>Dept</th><th>Salary</th><th>Payment</th><th>Status</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (employees.length === 0) { %>
            <tr><td colspan="7" class="text-center py-5 text-muted">No employees found.</td></tr>
          <% } %>
          <% employees.forEach((employee) => { %>
            <% const ps = employee.paymentStatus || 'Pending'; %>
            <tr>
              <td><span class="badge bg-light text-dark border"><%= employee.employeeId %></span></td>
              <td class="fw-semibold"><a href="/employee/<%= employee._id %>" class="text-decoration-none"><%= employee.fullName %></a></td>
              <td><%= employee.department %></td>
              <td>&#8377;<%= employee.currentSalary.toLocaleString() %></td>
              <td><span class="status-badge <%= ps === 'Paid' ? 'payment-status-paid' : 'payment-status-pending' %>"><%= ps %></span></td>
              <td><span class="status-badge <%= employee.status === 'Active' ? 'status-active' : employee.status === 'On Leave' ? 'status-leave' : 'status-inactive' %>"><%= employee.status %></span></td>
              <td class="text-nowrap">
                <% if (ps !== 'Paid') { %>
                  <button type="button" class="btn btn-sm btn-pay-salary me-1" data-pay-salary-mock data-employee-id="<%= employee._id %>"><i class="bi bi-credit-card"></i> Pay</button>
                <% } %>
                <a href="/employee/<%= employee._id %>" class="btn btn-sm btn-outline-primary rounded-pill">View</a>
                <a href="/employees/<%= employee._id %>/edit" class="btn btn-sm btn-outline-secondary rounded-pill">Edit</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include("../partials/mock-pay-scripts") %>
<%- include("../partials/footer") %>
