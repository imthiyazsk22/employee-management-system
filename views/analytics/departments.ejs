<%- include("../partials/header") %>
<%- include("../partials/navbar") %>
<div class="page-wrapper">
  <div class="d-flex align-items-center gap-3 mb-4">
    <a href="/dashboard" class="btn btn-sm btn-outline-secondary rounded-pill"><i class="bi bi-arrow-left"></i> Dashboard</a>
    <h1 class="page-title mb-0">Departments</h1>
  </div>
  <div class="row g-3">
    <% departments.forEach((d) => { %>
      <div class="col-md-6 col-lg-3">
        <div class="card stat-card h-100 border-0">
          <div class="card-body">
            <h5 class="fw-bold" style="color:var(--orange);"><%= d.name %></h5>
            <p class="mb-1"><i class="bi bi-people me-1"></i><strong><%= d.employeeCount %></strong> employees</p>
            <p class="mb-1 text-muted small">Total: &#8377;<%= d.totalSalary.toLocaleString() %></p>
            <p class="mb-1 text-muted small">Avg: &#8377;<%= Math.round(d.avgSalary || 0).toLocaleString() %></p>
            <span class="status-badge payment-status-paid"><%= d.paidCount %> paid</span>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>
<%- include("../partials/footer") %>
