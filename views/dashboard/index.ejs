<%- include("../partials/header") %>
<%- include("../partials/navbar") %>

<div class="page-wrapper">
  <%- include("../partials/messages") %>

  <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
      <h1 class="page-title mb-1">IM Solutions Dashboard</h1>
      <p class="page-subtitle mb-0">Employee Salary &amp; Hike Management — SaaS HR Console</p>
    </div>
    <a href="/employees/new" class="btn btn-primary px-4 rounded-pill">
      <i class="bi bi-person-plus-fill me-2"></i>Add Employee
    </a>
  </div>

  <!-- Drill-down stat tiles -->
  <div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
      <a href="/employees" class="dashboard-tile card stat-card stat-card-blue h-100 border-0">
        <div class="card-body d-flex align-items-center gap-3">
          <span class="stat-icon-wrap stat-icon-blue"><i class="bi bi-people-fill"></i></span>
          <div class="flex-grow-1">
            <div class="stat-label">Total Employees</div>
            <div class="stat-value"><%= stats.totalEmployees %></div>
            <div class="stat-footer">View all employees <i class="bi bi-arrow-right tile-arrow"></i></div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-sm-6 col-xl-3">
      <a href="/salary-expenses" class="dashboard-tile card stat-card stat-card-teal h-100 border-0">
        <div class="card-body d-flex align-items-center gap-3">
          <span class="stat-icon-wrap stat-icon-teal"><i class="bi bi-cash-stack"></i></span>
          <div class="flex-grow-1">
            <div class="stat-label">Salary Expenses</div>
            <div class="stat-value" style="font-size:1.2rem;">&#8377;<%= stats.totalSalaryExpense.toLocaleString() %></div>
            <div class="stat-footer">Breakdown <i class="bi bi-arrow-right tile-arrow"></i></div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-sm-6 col-xl-3">
      <a href="/salary-analysis" class="dashboard-tile card stat-card stat-card-violet h-100 border-0">
        <div class="card-body d-flex align-items-center gap-3">
          <span class="stat-icon-wrap stat-icon-violet"><i class="bi bi-graph-up-arrow"></i></span>
          <div class="flex-grow-1">
            <div class="stat-label">Avg Salary</div>
            <div class="stat-value" style="font-size:1.2rem;">&#8377;<%= Math.round(stats.averageSalary).toLocaleString() %></div>
            <div class="stat-footer">Analytics <i class="bi bi-arrow-right tile-arrow"></i></div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-sm-6 col-xl-3">
      <a href="/hike-details" class="dashboard-tile card stat-card stat-card-amber h-100 border-0">
        <div class="card-body d-flex align-items-center gap-3">
          <span class="stat-icon-wrap stat-icon-amber"><i class="bi bi-award-fill"></i></span>
          <div class="flex-grow-1">
            <div class="stat-label">Active Hikes</div>
            <div class="stat-value"><%= stats.employeesWithActiveHikes %></div>
            <div class="stat-footer">Hike details <i class="bi bi-arrow-right tile-arrow"></i></div>
          </div>
        </div>
      </a>
    </div>
  </div>

  <!-- Analytics insights -->
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="insight-card">
        <div class="text-muted small fw-semibold text-uppercase">Paid This Month</div>
        <div class="fs-4 fw-bold text-primary">&#8377;<%= stats.paidThisMonth.toLocaleString() %></div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="insight-card">
        <div class="text-muted small fw-semibold text-uppercase">Pending Payments</div>
        <div class="fs-4 fw-bold text-danger"><%= stats.pendingPayments %></div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="insight-card">
        <div class="text-muted small fw-semibold text-uppercase">Paid Employees</div>
        <div class="fs-4 fw-bold text-success"><%= stats.paidPayments %></div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="insight-card">
        <div class="text-muted small fw-semibold text-uppercase">Highest Paid</div>
        <% if (analytics.highestPaid) { %>
          <div class="fw-bold small"><%= analytics.highestPaid.fullName %></div>
          <div class="text-muted small">&#8377;<%= analytics.highestPaid.currentSalary.toLocaleString() %></div>
        <% } else { %>
          <div class="text-muted">—</div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-lg-7">
      <div class="card border-0 h-100" style="border-radius:var(--radius-md);">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h6 class="fw-bold mb-0"><i class="bi bi-bar-chart-fill text-primary me-2"></i>Salary Distribution</h6>
        </div>
        <div class="card-body"><div class="chart-box"><canvas id="salaryChart"></canvas></div></div>
      </div>
    </div>
    <div class="col-lg-5">
      <div class="card border-0 h-100" style="border-radius:var(--radius-md);">
        <div class="card-header"><h6 class="fw-bold mb-0"><i class="bi bi-pie-chart-fill text-primary me-2"></i>By Department</h6></div>
        <div class="card-body"><div class="chart-box"><canvas id="deptChart"></canvas></div></div>
      </div>
    </div>
  </div>

  <div class="row g-4 mt-1">
    <div class="col-lg-6">
      <div class="card border-0" style="border-radius:var(--radius-md);">
        <div class="card-header"><h6 class="fw-bold mb-0"><i class="bi bi-clock-history me-2"></i>Recent Activities</h6></div>
        <div class="card-body">
          <% if (!recentActivities || recentActivities.length === 0) { %>
            <p class="text-muted small mb-0">No activity yet.</p>
          <% } %>
          <% (recentActivities || []).forEach((act) => { %>
            <div class="activity-item d-flex justify-content-between gap-2">
              <div>
                <strong><%= act.action %></strong>
                <% if (act.employee) { %>
                  <span class="text-muted"> — <%= act.employee.fullName %></span>
                <% } %>
                <% if (act.details) { %><div class="text-muted small"><%= act.details %></div><% } %>
              </div>
              <small class="text-muted text-nowrap"><%= new Date(act.createdAt).toLocaleString('en-IN') %></small>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="card border-0" style="border-radius:var(--radius-md);">
        <div class="card-header d-flex justify-content-between">
          <h6 class="fw-bold mb-0">Recent Salary Changes</h6>
          <a href="/payment-history" class="small">Payment history</a>
        </div>
        <div class="table-responsive modern-table-wrap">
          <table class="table table-sm modern-table mb-0">
            <thead><tr><th>Employee</th><th>Hike</th><th>Date</th></tr></thead>
            <tbody>
              <% if (recentSalaryChanges.length === 0) { %>
                <tr><td colspan="3" class="text-center text-muted py-3">No records</td></tr>
              <% } %>
              <% recentSalaryChanges.forEach((item) => { %>
                <tr>
                  <td><%= item.employee?.fullName || "—" %></td>
                  <td><span class="hike-badge">+<%= item.hikePercentage %>%</span></td>
                  <td class="small"><%= new Date(item.createdAt).toLocaleDateString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(() => {
  const PALETTE = ['#2563EB','#7C3AED','#10B981','#F59E0B','#EF4444','#0D9488','#EC4899','#6366F1','#14B8A6','#1E3A8A'];
  const colorFor = (i) => PALETTE[i % PALETTE.length];
  const empData = <%- JSON.stringify(employeeSalaryData || []) %>;
  const deptData = <%- JSON.stringify(departmentCounts || []) %>;
  const salaryCtx = document.getElementById('salaryChart');
  if (salaryCtx && empData.length && typeof Chart !== 'undefined') {
    new Chart(salaryCtx, {
      type: 'bar',
      data: {
        labels: empData.map(e => e.fullName),
        datasets: [{
          label: 'Salary',
          data: empData.map(e => e.currentSalary),
          backgroundColor: empData.map((_, i) => colorFor(i)),
          borderColor: empData.map((_, i) => colorFor(i)),
          borderWidth: 1,
          borderRadius: 6
        }]
      },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
    });
  }
  const deptCtx = document.getElementById('deptChart');
  if (deptCtx && deptData.length && typeof Chart !== 'undefined') {
    new Chart(deptCtx, {
      type: 'doughnut',
      data: {
        labels: deptData.map(d => d._id),
        datasets: [{ data: deptData.map(d => d.count), backgroundColor: PALETTE, borderWidth: 2, borderColor: '#fff' }]
      },
      options: { responsive: true, maintainAspectRatio: false, cutout: '62%', plugins: { legend: { position: 'bottom' } } }
    });
  }
})();
</script>
<%- include("../partials/footer") %>
